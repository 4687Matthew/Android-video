<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/background"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 视频选择和基本信息区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/video_selection"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnSelectVideo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="@string/select_video"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/tvVideoPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/no_video_selected"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:maxLines="2"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/btnGetInfo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="@string/video_info"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/VideoInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:maxLines="4"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- 压缩功能区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/video_compression"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnCompressBase"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="@string/serial_compression"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>

            <Button
                android:id="@+id/btnCompress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/parallel_compression"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- 视频编辑功能区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/video_editing"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <!-- 裁剪视频 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/crop_video_title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etCropStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/start_time_hint"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etCropEnd"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/end_time_hint"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnCrop"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="@string/crop_video_button"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>

            <!-- 分割视频 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/split_video_title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etSplitTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/split_time_hint"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnSplit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/split_button"
                    android:minWidth="80dp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- 合并视频 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/merge_video_title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnSelectSecondVideo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="@string/select_second_video"
                android:backgroundTint="@color/secondary"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/tvSecondVideoPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/no_second_video_selected"
                android:textSize="12sp"
                android:textColor="@color/secondary_text"
                android:maxLines="2"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/btnMerge"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/merge_videos_button"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- 封面设置区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cover_settings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etCoverTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/cover_time_hint"
                    android:inputType="numberDecimal"
                    android:text="1.0"
                    android:background="@drawable/edittext_background"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnExtractCover"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/extract_cover"
                    android:minWidth="80dp"
                    android:backgroundTint="@color/secondary"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSelectCover"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="@string/select_cover_image"
                android:backgroundTint="@color/secondary"
                android:textColor="@color/white"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnSetCover"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/set_cover_to_video"
                    android:backgroundTint="@color/accent"
                    android:textColor="@color/white"/>

                <Button
                    android:id="@+id/btnSaveCover"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/save_cover"
                    android:backgroundTint="@color/accent"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- 封面预览 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="@color/preview_background"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cover_preview"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:layout_marginBottom="8dp"/>

                <!-- 使用FrameLayout作为容器 -->
                <FrameLayout
                    android:id="@+id/coverPreviewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/cover_preview_background"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivCoverPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_cover_placeholder"
                        android:layout_gravity="center"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/tvCoverInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_cover_extracted"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:textColor="@color/secondary_text"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 速度调节区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/speed_adjustment"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etSpeedFactor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/speed_factor_hint"
                android:inputType="numberDecimal"
                android:background="@drawable/edittext_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSpeedUp"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/speed_up_2x"
                    android:backgroundTint="@color/accent"
                    android:textColor="@color/white"/>

                <Button
                    android:id="@+id/btnSpeedDown"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/speed_down_05x"
                    android:backgroundTint="@color/accent"
                    android:textColor="@color/white"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 底部间距 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp"/>

    </LinearLayout>
</ScrollView>