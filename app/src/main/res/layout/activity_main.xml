<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 视频选择按钮 -->
        <Button
            android:id="@+id/btnSelectVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/select_video" />

        <TextView
            android:id="@+id/tvVideoPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="未选择视频"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnGetInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/video_info" />

        <TextView
            android:id="@+id/VideoInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text=""
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnCompressBase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="降低码率串行" />

        <Button
            android:id="@+id/btnCompress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="降低码率并行" />

        <!-- 裁剪视频 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="裁剪视频"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etCropStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/start_time"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etCropEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/end_time"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/btnCrop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/crop_video" />

        <!-- 分割视频 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="分割视频"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etSplitTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/split_time"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/btnSplit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/split_video" />

        <!-- 合并视频 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="合并视频"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSelectSecondVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_second_video" />

        <TextView
            android:id="@+id/tvSecondVideoPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="未选择第二个视频"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnMerge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/merge_videos" />

        <!-- 速度调节 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="速度调节"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etSpeedFactor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/speed_factor"
            android:inputType="numberDecimal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnSpeedUp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/speed_up" />

            <Button
                android:id="@+id/btnSpeedDown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/speed_down" />
        </LinearLayout>

        <!-- 进度显示 -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textAlignment="center" />


    </LinearLayout>
</ScrollView>

